# ===========================================
# NegociAí - Variáveis de Ambiente
# ===========================================
# Copie este arquivo para ".env.local" e preencha os valores.
# O app funciona mesmo sem chaves (usa gerador local de fallback),
# mas para usar a IA da OpenAI e salvar no Supabase preencha abaixo.

# --- OpenAI (geração das mensagens) ---
OPENAI_API_KEY=
# Modelo opcional (padrão: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# --- Supabase (auth + banco) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Chave service_role (somente server-side, NUNCA exponha no client)
SUPABASE_SERVICE_ROLE_KEY=
# No Supabase: Authentication → Providers → Email (habilitar)
# Para login imediato após cadastro: desative "Confirm email" em Email provider
# Rode supabase/schema.sql no SQL Editor (tabela profiles)

# --- Asaas (pagamento: PIX e cartão) ---
ASAAS_API_KEY=
# Ambiente do Asaas: "sandbox" (padrão) ou "production"
ASAAS_ENV=sandbox

# Segredo para assinar o cookie de acesso liberado após o pagamento.
# Use uma string longa e aleatória em produção.
ACCESS_SECRET=troque-por-uma-string-aleatoria-longa

# --- App ---
# Local: http://localhost:3000
# Vercel: https://seu-projeto.vercel.app (ou deixe vazio — usa VERCEL_URL)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PRICE_BRL=19.90
